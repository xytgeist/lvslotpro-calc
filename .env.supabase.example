# Copy to .env.supabase.test and/or .env.supabase.production (gitignored).
# Used by scripts/supabase-db-query.mjs and slot sync scripts.

# Test: kcosfvmreeiosdjdzycb (lvslotpro.com sandbox)
# Production: jtjgtucumuoswnbauxry (edgetilt.com)

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Dashboard → Settings → Database → Database password.
# Required for reliable CLI SQL (avoids cli_login_postgres pooler SASL / circuit-breaker failures).
SUPABASE_DB_PASSWORD=

# Optional: full postgres URL (session pooler or direct). Overrides pooler-url + password builder.
# SUPABASE_DB_URL=postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
